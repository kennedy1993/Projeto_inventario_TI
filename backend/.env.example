# ==============================================================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o arquivo .env para o Git.
# ==============================================================================

# Chave da API Groq (https://console.groq.com)
GROQ_API_KEY=sua_chave_groq_aqui

# URL de conexão com o PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/itam_avanco?application_name=itam_api

# Origens permitidas no CORS (separadas por vírgula)
# Em produção, coloque apenas o domínio real — sem localhost
ALLOWED_ORIGINS=https://seu-dominio.com.br,https://www.seu-dominio.com.br
