# ==============================================================================
# VARIÁVEIS DE AMBIENTE - DOCKER COMPOSE
# Copie este arquivo para ".env" (na raiz do projeto, mesmo nível do
# docker-compose.yml) e preencha os valores reais.
# NUNCA suba o arquivo .env para o Git (já está no .gitignore).
# ==============================================================================

# Senha do usuário "postgres" dentro do container do banco.
POSTGRES_PASSWORD=troque_por_uma_senha_forte

# Chave da API Groq (https://console.groq.com) - usada pelo assistente de IA.
GROQ_API_KEY=sua_chave_groq_aqui

# Origens permitidas no CORS, separadas por vírgula.
# Deixe em branco para liberar geral (*) - ok pra uso atrás do Cloudflare Tunnel,
# já que o app não usa cookies/sessão baseada em origem.
ALLOWED_ORIGINS=
